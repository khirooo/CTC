# Caddyfile.http — plain HTTP variant for VPN/trusted-LAN deployments.
# Use this when CTC_WEB_TRANSPORT=http (the shipped default).
#
# WARNING: HTTP means session cookies and magic-link tokens travel in plaintext.
# Only use this behind a VPN or on a trusted internal network.
# For public deployments set CADDYFILE=Caddyfile (HTTPS with TLS).
#
# Select this file in docker-compose.yml by setting: CADDYFILE=Caddyfile.http

{
	auto_https off
}

http://{$CTC_DOMAIN} {
	encode gzip

	# The proxy's CA cert, so `ctc login` can fetch it from http://<domain>/ctc-ca.pem.
	# Served from the shared cert volume mounted at /certs.
	handle /ctc-ca.pem {
		root * /certs
		rewrite * /cert.pem
		file_server
	}

	# Control-plane: OAuth + API. (Same origin as the web app, so no CORS hop.)
	handle /api/* {
		reverse_proxy controlplane:8090
	}
	handle /auth/* {
		reverse_proxy controlplane:8090
	}

	# Everything else: the static web app and the CLI assets (/install.sh, /ctc),
	# with SPA fallback to index.html for client-side routes.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
