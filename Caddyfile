# Caddy fronts the public surface: it terminates HTTPS (auto Let's Encrypt for a
# real domain), serves the web app + CLI assets, and reverse-proxies the API.
# CTC_DOMAIN comes from .env (use "localhost" for a local test — Caddy then uses
# its internal CA).

{
	# Browsers send NO SNI when connecting to a bare IP (SNI carries hostnames
	# only, per RFC 6066). Without a default, Caddy can't choose a cert for a
	# no-SNI handshake and aborts it with a TLS "internal error" — so an IP-valued
	# CTC_DOMAIN fails in the browser (hard ERR_SSL_PROTOCOL_ERROR, no "proceed")
	# even when the cert is valid. Naming the default makes no-SNI handshakes
	# resolve to our site. Harmless for hostname deploys (browsers send SNI there).
	default_sni {$CTC_DOMAIN}
}

{$CTC_DOMAIN} {
	encode gzip

	# Access log for every request (off by default in Caddy — must be explicit).
	log {
		output stdout
		format console
	}
	# Use the shared self-signed proxy cert (not Caddy's internal CA) so the cert
	# `ctc login` trusts also fronts the dashboard — no separate trust, no warning
	# after install. /certs is the same volume the proxy and gencert write.
	tls /certs/cert.pem /certs/key.pem

	# The proxy's CA cert, so `ctc login` can fetch it from https://<domain>/ctc-ca.pem.
	# Served from the shared cert volume mounted at /certs.
	handle /ctc-ca.pem {
		root * /certs
		rewrite * /cert.pem
		file_server
	}

	# Control-plane: OAuth + API. (Same origin as the web app, so no CORS hop.)
	handle /api/* {
		reverse_proxy controlplane:8090
	}
	handle /auth/* {
		reverse_proxy controlplane:8090
	}

	# Everything else: the static web app and the CLI assets (/install.sh, /ctc),
	# with SPA fallback to index.html for client-side routes.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
