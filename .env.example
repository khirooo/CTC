# Copy to `.env` and fill in. Never commit the real .env (it's gitignored).

# ── Where CTC is served (the one host knob) ──────────────────────────────────
# Sets the web app + API origin AND drives the CLI install command, the proxy
# host shown in "Set up CLI", and the launcher's default host — all derived from
# this single value. Use a hostname OR a raw IP:
#   CTC_DOMAIN=ctc.company.com   → public/internal DNS name (Let's Encrypt if public)
#   CTC_DOMAIN=10.0.0.5          → raw internal IP (Caddy serves HTTPS via its
#                                   internal CA; teammates trust that CA once —
#                                   see docs/guide/07-deploying.md)
#   CTC_DOMAIN=localhost         → local test (Caddy internal CA)
CTC_DOMAIN=ctc.example.com

# ── Secrets ──────────────────────────────────────────────────────────────────
# One key, shared by the proxy + control plane. It encrypts stored PATs and
# signs session/state cookies. Generate once, keep secret, never change it
# (changing it makes stored PATs undecryptable). e.g.  openssl rand -hex 32
CTC_SECRET_KEY=change-me-to-a-long-random-secret

# ── Deployment mode (shipped defaults target license-holders-trade-credits) ──
# Auth: email magic-link (no GHE account needed) or ghe_oauth.
CTC_AUTH_MODE=email
# Website transport. http = plain HTTP (NO TLS) — ONLY behind a VPN/trusted LAN,
# because session cookies + magic links travel in plaintext. Must match
# CTC_APP_ORIGIN scheme. For public TLS use https + CADDYFILE=Caddyfile.
CTC_WEB_TRANSPORT=http
# Caddy config file to mount. Default (unset) = Caddyfile (HTTPS with TLS).
# Set to Caddyfile.http for plain HTTP mode (CTC_WEB_TRANSPORT=http).
CADDYFILE=Caddyfile.http
# Live admin toggles seed their FIRST-BOOT default from these; afterwards the
# admin panel value wins.
CTC_PARTICIPANTS_MODE=givers_only        # or givers_and_consumers
CTC_SHARED_POOL=off                      # or on

# ── Email (magic-link) ───────────────────────────────────────────────────────
CTC_EMAIL_BACKEND=console                # console logs the link; use smtp in prod
CTC_SMTP_HOST=
CTC_SMTP_PORT=587
CTC_SMTP_USER=
CTC_SMTP_PASS=
CTC_SMTP_FROM=ctc@your-company.com
CTC_SMTP_STARTTLS=1

# ── GitHub Enterprise OAuth app ──────────────────────────────────────────────
# Only required when CTC_AUTH_MODE=ghe_oauth.
# Register an OAuth app on your GHE with callback https://<CTC_DOMAIN>/auth/callback
GHE_OAUTH_CLIENT_ID=your-ghe-oauth-client-id
GHE_OAUTH_CLIENT_SECRET=your-ghe-oauth-client-secret

# Your GitHub Enterprise domain. The proxy derives the hosts it decrypts/swaps
# from this (contract.py), the cert SANs come from it (gen-cert.sh), and the CLI
# launcher uses it for GH_HOST. Set it once here to your real GHE domain.
GHE_DOMAIN=example.ghe.com

# GHE hosts. OAUTH_BASE = the web host (login + /api/v3/user) — only used in
# ghe_oauth mode. GHE_API_BASE = the API host that serves /copilot_internal/user
# (Copilot quota / PAT validation). REQUIRED in BOTH auth modes — PAT validation
# always uses the API host regardless of login method. (Changed in Task 8: no
# longer defaults to GHE_OAUTH_BASE; must be set explicitly.)
GHE_OAUTH_BASE=https://example.ghe.com
GHE_API_BASE=https://api.example.ghe.com

# The real GHE API host the proxy forwards Copilot traffic to.
REAL_GHE_HOST=api.example.ghe.com

# ── Proxy network exposure (VPN/internal only) ───────────────────────────────
# The proxy is an HTTP CONNECT proxy — do NOT expose it to the open internet.
# Set this to the VM's VPN/internal-facing IP so only teammates on the VPN can
# reach port 8080. Leave as 127.0.0.1 to keep it localhost-only.
PROXY_BIND=127.0.0.1

# ── Admin panel ──────────────────────────────────────────────────────────────
# Comma-separated identities that get the admin panel (see all users, reveal
# PATs, edit global defaults). Case-insensitive. Lock this down like a secret —
# an admin can reveal every giver's real PAT. Empty/unset = nobody is admin.
# In ghe_oauth mode: list GHE LOGIN NAMES. In email mode: list EMAIL ADDRESSES.
CTC_ADMINS=your-ghe-login

# ── Defaults ─────────────────────────────────────────────────────────────────
# % of a giver's REMAINING quota auto-pledged to the shared pool when they submit
# their PAT (they can change it afterwards in Settings). Default 10.
CTC_DEFAULT_PLEDGE_PCT=10
